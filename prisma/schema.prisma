// ─── AI Platform Core ──────────────────────────────────────────────

model AiAuditLog {
  id              String          @id @default(cuid())
  shopId          String          @map("shop_id")
  userId          String?         @map("user_id")
  conversationId  String?         @map("conversation_id")
  action          String
  toolName        String?         @map("tool_name")
  params          Json?
  beforeState     Json?           @map("before_state")
  afterState      Json?           @map("after_state")
  status          AiActionStatus
  riskLevel       AiActionRisk    @default(LOW) @map("risk_level")
  requiresApproval Boolean        @default(false) @map("requires_approval")
  approvedBy      String?         @map("approved_by")
  approvedAt      DateTime?       @map("approved_at")
  executionTimeMs Int?            @map("execution_time_ms")
  errorMessage    String?         @map("error_message")
  rollbackData    Json?           @map("rollback_data")
  costTokens      Int?            @map("cost_tokens")
  costUsd         Float?          @map("cost_usd")
  createdAt       DateTime        @default(now()) @map("created_at")
  
  shop            Shop            @relation(fields: [shopId], references: [id], onDelete: Cascade)
  user            User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  @@index([shopId, createdAt])
  @@index([status, riskLevel])
  @@index([userId, createdAt])
  @@map("ai_audit_logs")
}

model KnowledgeDocument {
  id              String          @id @default(cuid())
  shopId          String          @map("shop_id")
  type            String          // product, policy, faq, support_ticket, custom
  sourceId        String?         @map("source_id")  // e.g., productId, orderId
  title           String
  content         String          @db.Text
  contentVector   Json?           @map("content_vector")  // Store embeddings as JSON array; migrate to pgvector when available
  metadata        Json?
  chunkIndex      Int?            @map("chunk_index")
  totalChunks     Int?            @map("total_chunks")
  isActive        Boolean         @default(true) @map("is_active")
  lastSyncedAt    DateTime        @default(now()) @map("last_synced_at")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  
  shop            Shop            @relation(fields: [shopId], references: [id], onDelete: Cascade)
  
  @@index([shopId, type])
  @@index([sourceId])
  @@index([isActive, updatedAt])
  @@map("knowledge_documents")
}

model AiJob {
  id              String          @id @default(cuid())
  shopId          String          @map("shop_id")
  type            String          // generate_content, optimize_media, build_embeddings, etc.
  status          String          // pending, processing, completed, failed
  priority        Int             @default(5)
  payload         Json
  result          Json?
  error           String?
  attempts        Int             @default(0)
  maxAttempts     Int             @default(3) @map("max_attempts")
  startedAt       DateTime?       @map("started_at")
  completedAt     DateTime?       @map("completed_at")
  createdAt       DateTime        @default(now()) @map("created_at")
  
  @@index([status, priority])
  @@index([shopId, type])
  @@index([createdAt])
  @@map("ai_jobs")
}

model UserMeasurement {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  label         String?  // e.g. "chest", "waist", "inseam", "neck", "shoulder"
  value         Float
  unit          String   @default("cm") // cm, inch, mm
  notes         String?
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isActive])
  @@map("user_measurements")
}

model CartEvent {
  id              String    @id @default(cuid())
  shopId          String    @map("shop_id")
  productId       String    @map("product_id")
  userId          String?   @map("user_id")
  sessionId       String?   @map("session_id")
  customerName    String?   @map("customer_name")
  customerEmail   String?   @map("customer_email")
  customerPhone   String?   @map("customer_phone")
  event           String    // add_to_cart, checkout_started, payment_completed, abandoned
  quantity        Int       @default(1)
  unitPrice       Float     @default(0) @map("unit_price")
  currency        String    @default("EGP")
  metadata        Json?
  isRecovered     Boolean   @default(false) @map("is_recovered")
  recoveredAt     DateTime? @map("recovered_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  shop            Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId, event])
  @@index([shopId, createdAt])
  @@index([shopId, productId])
  @@index([userId, shopId])
  @@index([sessionId])
  @@index([isRecovered])
  @@map("cart_events")
}
