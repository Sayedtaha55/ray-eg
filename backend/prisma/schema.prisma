generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// Enums
enum UserRole {
  USER
  MERCHANT
  ADMIN
  COURIER
}

enum ShopStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum NotificationType {
  ORDER
  MESSAGE
  PROMOTION
  SYSTEM
}

enum ShopModuleUpgradeRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELED
}

// Models
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      UserRole @default(USER)
  phone     String?  @unique
  isActive  Boolean  @default(true)
  deactivatedAt DateTime? @map("deactivated_at")
  scheduledPurgeAt DateTime? @map("scheduled_purge_at")
  lastLogin DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  shop      Shop?
  orders    Order[]
  messages  Message[] @relation("SentMessages")
  notifications Notification[]
  feedback  Feedback[]
  reservations Reservation[]
  receivedMessages Message[] @relation("ReceivedMessages")
  followingShops Shop[] @relation("ShopFollowers")
  notificationPreferences NotificationPreference?
  userMeasurements UserMeasurement[]

  @@index([role, isActive, createdAt])
  @@index([isActive, createdAt])
  @@map("users")
}

model UserMeasurement {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  label     String?
  value     Float
  unit      String   @default("cm")
  notes     String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isActive])
  @@map("user_measurements")
}

model Shop {
  id               String     @id @default(cuid())
  name             String
  slug             String     @unique
  description      String?
  logo             String?
  logoUrl          String?    @map("logo_url")
  coverImage       String?
  bannerUrl        String?    @map("banner_url")
  phone            String?
  email            String?
  address          String?
  addressDetailed  String?
  displayAddress   String?
  mapLabel         String?
  latitude         Float?
  longitude        Float?
  locationSource   String?
  locationAccuracy Float?
  locationUpdatedAt DateTime?
  openingHours     String?
  website          String?
  status           ShopStatus @default(PENDING)
  category         String     @default("RETAIL")
  governorate      String?
  city             String?
  deliveryFee      Float?     @map("delivery_fee")
  deliveryDisabled  Boolean    @default(false) @map("delivery_disabled")
  isActive         Boolean    @default(true)
  visitors         Int        @default(0)
  followers        Int        @default(0)
  addons           Json?
  pageDesign       Json?      @map("page_design")
  layoutConfig     Json?      @map("layout_config")
  ownerId          String   @unique
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  // Relations
  owner            User       @relation(fields: [ownerId], references: [id])
  products         Product[]
  orders           Order[]
  offers           Offer[]
  gallery          ShopGallery[]
  analytics        ShopAnalytics?
  theme            ShopTheme?
  followersList    User[]     @relation("ShopFollowers")
  reservations     Reservation[]
  feedback         Feedback[]
  visits           Visit[]
  imageMaps        ShopImageMap[]
  moduleUpgradeRequests ShopModuleUpgradeRequest[]

  @@map("shops")
}

model ShopModuleUpgradeRequest {
  id                String                        @id @default(cuid())
  shopId             String                       @map("shop_id")
  status             ShopModuleUpgradeRequestStatus @default(PENDING)
  requestedModules   Json                         @map("requested_modules")
  reviewedAt         DateTime?                    @map("reviewed_at")
  note               String?
  requestedByUserId  String?                      @map("requested_by_user_id")
  reviewedByAdminId  String?                      @map("reviewed_by_admin_id")
  createdAt          DateTime                     @default(now()) @map("created_at")
  updatedAt          DateTime                     @updatedAt @map("updated_at")

  shop              Shop                          @relation(fields: [shopId], references: [id])

  @@index([shopId])
  @@index([status])
  @@map("shop_module_upgrade_requests")
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Float
  stock       Int      @default(0)
  trackStock  Boolean  @default(true) @map("track_stock")
  category    String   @default("عام")
  unit        String?
  packOptions Json?    @map("pack_options")
  imageUrl    String?  @map("image_url")
  images      Json?
  colors      Json?
  sizes       Json?
  addons      Json?
  menuVariants Json?   @map("menu_variants")
  isActive    Boolean  @default(true)
  shopId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  shop        Shop     @relation(fields: [shopId], references: [id])
  orderItems  OrderItem[]
  offers      Offer[]
  feedback    Feedback[]
  imageHotspots ShopImageHotspot[]
  furnitureMeta ProductFurnitureMeta?

  @@index([shopId, isActive, createdAt])
  @@map("products")
}

model ProductFurnitureMeta {
  id        String   @id @default(cuid())
  productId String   @unique @map("product_id")
  unit      String?
  lengthCm  Float?   @map("length_cm")
  widthCm   Float?   @map("width_cm")
  heightCm  Float?   @map("height_cm")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_furniture_meta")
}

model ShopImageMap {
  id        String   @id @default(cuid())
  shopId    String   @map("shop_id")
  title     String?
  imageUrl  String   @map("image_url")
  width     Int?
  height    Int?
  isActive  Boolean  @default(true) @map("is_active")
  aiMeta    Json?    @map("ai_meta")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  shop      Shop     @relation(fields: [shopId], references: [id])
  sections  ShopImageSection[]
  hotspots  ShopImageHotspot[]

  @@index([shopId])
  @@map("shop_image_maps")
}

model ShopImageSection {
  id        String   @id @default(cuid())
  mapId     String   @map("map_id")
  name      String
  sortOrder Int      @default(0) @map("sort_order")
  imageUrl  String?  @map("image_url")
  width     Int?
  height    Int?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  map       ShopImageMap @relation(fields: [mapId], references: [id], onDelete: Cascade)
  hotspots  ShopImageHotspot[]

  @@index([mapId])
  @@map("shop_image_sections")
}

model ShopImageHotspot {
  id            String   @id @default(cuid())
  mapId         String   @map("map_id")
  sectionId     String?  @map("section_id")
  productId     String?  @map("product_id")
  x             Float
  y             Float
  width         Float?   @map("width")
  height        Float?   @map("height")
  label         String?
  sortOrder     Int      @default(0) @map("sort_order")
  priceOverride Float?   @map("price_override")
  isActive      Boolean  @default(true) @map("is_active")
  aiMeta        Json?    @map("ai_meta")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  map       ShopImageMap      @relation(fields: [mapId], references: [id], onDelete: Cascade)
  section   ShopImageSection? @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  product   Product?          @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([mapId])
  @@index([sectionId])
  @@index([productId])
  @@map("shop_image_hotspots")
}

model Offer {
  id          String   @id @default(cuid())
  title       String
  description String?
  discount    Float
  oldPrice    Float?   @map("old_price")
  newPrice    Float?   @map("new_price")
  imageUrl    String?  @map("image_url")
  isActive    Boolean  @default(true)
  startDate   DateTime
  endDate     DateTime
  expiresAt   DateTime? @map("expires_at")
  shopId      String
  productId   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  shop        Shop     @relation(fields: [shopId], references: [id])
  product     Product? @relation(fields: [productId], references: [id])

  @@map("offers")
}

model Order {
  id            String        @id @default(cuid())
  totalAmount   Float         @map("total_amount")
  total         Float         @default(0)
  status        OrderStatus   @default(PENDING)
  paymentStatus PaymentStatus @default(PENDING)
  paymentMethod String?
  source        String?       @default("customer")
  userId        String        @map("user_id")
  shopId        String        @map("shop_id")
  handedToCourierAt DateTime?  @map("handed_to_courier_at")
  notes         String?
  deliveredAt   DateTime?      @map("delivered_at")
  codCollectedAt DateTime?     @map("cod_collected_at")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  // Relations
  user          User          @relation(fields: [userId], references: [id])
  shop          Shop          @relation(fields: [shopId], references: [id])
  items         OrderItem[]

  @@index([shopId, status, createdAt])
  @@index([userId, createdAt])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id        String @id @default(cuid())
  quantity  Int
  price     Float
  orderId   String
  productId String
  variantSelection Json? @map("variant_selection")

  // Relations
  order     Order   @relation(fields: [orderId], references: [id])
  product   Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model Message {
  id        String   @id @default(cuid())
  content   String
  senderId  String
  receiverId String
  shopId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  sender    User @relation("SentMessages", fields: [senderId], references: [id])
  receiver  User @relation("ReceivedMessages", fields: [receiverId], references: [id])

  @@map("messages")
}

model Notification {
  id        String           @id @default(cuid())
  title     String
  content   String
  type      NotificationType
  userId    String?
  shopId    String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  // Relations
  user      User?            @relation(fields: [userId], references: [id])

  @@map("notifications")
}

model Reservation {
  id          String   @id @default(cuid())
  name        String
  email       String
  phone       String
  date        DateTime
  time        String
  guests      Int
  specialRequests String?
  status      String   @default("pending")
  shopId      String
  userId      String
  variantSelection Json? @map("variant_selection")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  shop        Shop     @relation(fields: [shopId], references: [id])
  user        User     @relation(fields: [userId], references: [id])

  @@map("reservations")
}

model Feedback {
  id        String   @id @default(cuid())
  rating    Int
  comment   String?
  userId    String?
  userName  String?
  userEmail String?
  shopId    String?
  productId String?
  status    String   @default("PENDING")
  createdAt DateTime @default(now())

  // Relations
  user      User?    @relation(fields: [userId], references: [id])
  shop      Shop?    @relation(fields: [shopId], references: [id])
  product   Product? @relation(fields: [productId], references: [id])

  @@map("feedback")
}

model ShopGallery {
  id        String   @id @default(cuid())
  imageUrl  String
  mediaType MediaType @default(IMAGE)
  thumbUrl  String?
  mediumUrl String?
  caption   String?
  shopId    String
  createdAt DateTime @default(now())

  // Relations
  shop      Shop     @relation(fields: [shopId], references: [id])

  @@map("shop_gallery")
}

model ShopAnalytics {
  id             String   @id @default(cuid())
  shopId         String   @unique
  revenue        Float    @default(0)
  ordersCount    Int      @default(0)
  visitorsCount  Int      @default(0)
  followersCount Int      @default(0)
  lastUpdated    DateTime @default(now())

  // Relations
  shop           Shop     @relation(fields: [shopId], references: [id])

  @@map("shop_analytics")
}

model ShopTheme {
  id           String @id @default(cuid())
  shopId       String @unique
  templateId   String
  primaryColor String
  secondaryColor String
  accentColor  String
  backgroundColor String
  textColor    String
  fontFamily   String
  borderRadius String
  customCSS    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  shop         Shop   @relation(fields: [shopId], references: [id])

  @@map("shop_themes")
}

model ThemeTemplate {
  id           String @id @default(cuid())
  name         String @unique
  displayName  String
  description  String
  category     String
  primaryColor String
  secondaryColor String
  accentColor  String
  backgroundColor String
  textColor    String
  fontFamily   String
  borderRadius String
  createdAt    DateTime @default(now())

  @@map("theme_templates")
}

model Visit {
  id        String   @id @default(cuid())
  shopId    String
  date      DateTime @default(now())
  ipHash    String?  // Hashed IP for uniqueness check (privacy-preserving)
  userAgent String?  // Browser info
  source    String?  // referrer source (direct, search, social, etc.)
  path      String?  // path visited (/shop/:slug)
  
  // Relations
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  
  @@unique([shopId, date, ipHash]) // Prevent duplicate visits per day per IP
  @@index([shopId, date])
  @@map("visits")
}

model NotificationPreference {
  id           String   @id @default(cuid())
  userId       String   @unique
  emailEnabled Boolean  @default(true)
  smsEnabled   Boolean  @default(false)
  pushEnabled  Boolean  @default(true)
  inAppEnabled Boolean  @default(true)
  typeSettings Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  user         User     @relation(fields: [userId], references: [id])

  @@map("notification_preferences")
}

enum MapListingStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

model MapListing {
  id                String           @id @default(cuid())
  title             String
  category          String?
  description       String?
  websiteUrl        String?          @map("website_url")
  phone             String?
  whatsapp          String?
  socialLinks       Json?            @map("social_links")
  logoUrl           String?          @map("logo_url")
  coverUrl          String?          @map("cover_url")
  linkedShopId      String?          @map("linked_shop_id")
  status            MapListingStatus @default(PENDING)
  reviewedAt        DateTime?        @map("reviewed_at")
  reviewedByAdminId String?          @map("reviewed_by_admin_id")
  reviewNote        String?          @map("review_note")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  branches          MapListingBranch[]
  ownerships        MapListingOwnership[]
  claimRequests     MapListingClaimRequest[]
  analyticsEvents   MapListingAnalyticsEvent[]

  @@index([status])
  @@index([category])
  @@map("map_listings")
}

model MapListingBranch {
  id           String      @id @default(cuid())
  listingId    String      @map("listing_id")
  name         String?
  latitude     Float
  longitude    Float
  addressLabel String?     @map("address_label")
  governorate  String?
  city         String?
  phone        String?
  isPrimary    Boolean     @default(false) @map("is_primary")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  listing      MapListing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@index([governorate])
  @@index([latitude, longitude])
  @@map("map_listing_branches")
}

model MapListingOwner {
  id        String   @id @default(cuid())
  phone     String   @unique
  name      String?
  email     String?
  avatarUrl String?  @map("avatar_url")
  isActive  Boolean  @default(true) @map("is_active")
  lastLogin DateTime? @map("last_login")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  ownerships    MapListingOwnership[]
  claimRequests MapListingClaimRequest[]

  @@index([phone])
  @@index([isActive])
  @@map("map_listing_owners")
}

enum OwnershipRole {
  OWNER
  MANAGER
}

model MapListingOwnership {
  id        String        @id @default(cuid())
  listingId String        @map("listing_id")
  ownerId   String        @map("owner_id")
  role      OwnershipRole @default(OWNER)
  grantedAt DateTime      @default(now()) @map("granted_at")

  listing MapListing      @relation(fields: [listingId], references: [id], onDelete: Cascade)
  owner   MapListingOwner @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@unique([listingId, ownerId])
  @@index([listingId])
  @@index([ownerId])
  @@index([ownerId, role])
  @@map("map_listing_ownerships")
}

enum ClaimRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model MapListingClaimRequest {
  id          String             @id @default(cuid())
  listingId   String             @map("listing_id")
  ownerId     String             @map("owner_id")
  otpVerified Boolean            @default(false) @map("otp_verified")
  status      ClaimRequestStatus @default(PENDING)
  adminNote   String?            @map("admin_note")
  reviewedAt  DateTime?          @map("reviewed_at")
  reviewedBy  String?            @map("reviewed_by")
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")

  listing MapListing      @relation(fields: [listingId], references: [id], onDelete: Cascade)
  owner   MapListingOwner @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@index([ownerId])
  @@index([status])
  @@map("map_listing_claim_requests")
}

enum AnalyticsEventType {
  LISTING_VIEW
  WEBSITE_CLICK
  WHATSAPP_CLICK
  PHONE_CLICK
  DIRECTIONS_CLICK
}

model MapListingAnalyticsEvent {
  id        String             @id @default(cuid())
  listingId String             @map("listing_id")
  type      AnalyticsEventType
  ip        String?
  userAgent String?            @map("user_agent")
  meta      Json?
  createdAt DateTime           @default(now()) @map("created_at")

  listing MapListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@index([listingId, type])
  @@index([listingId, createdAt])
  @@index([createdAt])
  @@map("map_listing_analytics_events")
}

model PortalOtpCode {
  id        String   @id @default(cuid())
  phone     String
  codeHash  String   @map("code_hash")
  purpose   String   @default("login")
  attempts  Int      @default(0)
  verified  Boolean  @default(false)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([phone, purpose])
  @@index([expiresAt])
  @@map("portal_otp_codes")
}

enum MediaType {
  IMAGE
  VIDEO
}
