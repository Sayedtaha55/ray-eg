{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "experimentalDecorators": true,
    "module": "CommonJS",
    "moduleResolution": "node",
    "allowImportingTsExtensions": false,
    "baseUrl": ".",
    "paths": {
      "@core/*": ["src/core/*"],
      "@common/*": ["src/common/*"],
      "@modules/*": ["src/modules/*"],
      "@shared/*": ["src/shared/*"]
    },
    "outDir": "../dist-backend",
    "rootDir": "./",
    "noEmit": false,
    "emitDecoratorMetadata": true,
    "esModuleInterop": true,
    "resolveJsonModule": true
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "../node_modules",
    "../dist",
    "../services",
    "../components",
    "../src"
  ]
}
