# ----------------------------------------------------------------
# Next.js Frontend — Environment Variables
# Copy this file to .env.local and fill in your actual values.
# ----------------------------------------------------------------

# --- Backend URL (server-side) ---
# Used by serverFetch() in Server Components to call NestJS
BACKEND_URL=http://localhost:4000

# --- Public API URL (client-side) ---
# Used by clientFetch() — proxied through Next.js rewrites to backend
NEXT_PUBLIC_API_URL=/api/v1

# --- App URL ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
